{
  "manifest_version": 3,
  "name": "Todo List App",
  "version": "1.0.0",
  "description": "Task management app with AI planning assistant - New Tab",
  "icons": {
    "16": "icon-192.png",
    "48": "icon-192.png",
    "128": "icon-512.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.firebaseapp.com",
    "https://*.firebasestorage.app",
    "https://*.googleapis.com"
  ]
}